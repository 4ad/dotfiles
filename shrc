# Don't set -e because we want to be able to login even if sourcing
# the profile fails.

os=$(uname -s)
host=$(uname -n)
host=${host%%.*}

# bosh (Schily Bourne Shell) needs this for command substitution
# in PS1.
(set -o promptcmdsubst) >/dev/null 2>&1 && set -o promptcmdsubst

# macOS Terminal.app may inject a broken LC_CTYPE=UTF-8 value.
if [ "${LC_CTYPE-}" = UTF-8 ]; then
	unset LC_CTYPE
fi

# Prompt is set here before the Plan 9 tools because they might
# overwrite it for dumb terminals.
PS1='$(printf "%s" "'"${host}"':`basename "${PWD}"`$ ")'
# Above prompt doesn't work in zsh, fixed in .zshrc

CDPATH=.:$HOME
if [ -d $HOME/src ]; then
	CDPATH=$CDPATH:$HOME/src:$HOME/src/mgk.ro:$HOME/src/mgk.ro/cmd:$HOME/src/mgk.ro/cmd/plan9
fi

# PAGER is set before the Plan 9 tools because they might
# overwrite it.
if command -v less >/dev/null 2>&1; then
	export PAGER=less
	export LESS='-imEQX'
else
	export PAGER=more
	export MORE='-ei'
fi

if [ -n "$PLAN9" ]; then
	# Some Plan9 tools work only in graphical environments.
	if [ -n "$DISPLAY" ] || [ "$os" = Darwin ] || [ "$termprog" = 9term ] || [ "$termprog" = win ];
	then
		# Plumb files instead of starting new editor.
		export EDITOR=E
		if command -v editinacme >/dev/null 2>&1; then
			export EDITOR=editinacme
		fi
		export VISUAL=$EDITOR

		# Keep the label up to date, so plumber works
		_cd () {
			\cd "$@" &&
			case $- in
			*i*)
				awd
			esac
		}
		alias cd=_cd
		cd .
	fi

	# If running in 9term or acme, make the environment
	# more Plan9 like.
	if [ "$TERM" = 9term ] || [ "$TERM" = dumb ]; then
		# Disable readline
		set +o emacs
		set +o vi
		# Make man work in 9term and acme's win,
		export PAGER="$(command -v nobs 2>/dev/null)" # Solaris needs full path
		# Set prompt so we can execute whole line
		# without $PS1 interfering.
		PS1='$(printf "%s" "'": ${host}"':`basename "${PWD}"`; ")'
	fi

	_acme() {
		if [ -f "$HOME/acme.dump" ]; then
			acme -a -l "$HOME/acme.dump" "$@"
		else
			acme -a "$@"
		fi
	}

	_rc() {
		PATH=.:$PLAN9/bin:$PATH rc "$@"
	}
	export prompt="$host% "

	alias acme=_acme
	alias sam='sam -a'
	alias rc=_rc
	alias lc='9 lc'
fi

# Some aliases.
alias git10="git log -n10 --no-merges --first-parent --pretty=format:'%h %s (%an)'"
alias git20="git log -n20 --no-merges --first-parent --pretty=format:'%h %s (%an)'"
alias t='tmux'
alias ta='tmux attach'
